---
import type { Translations } from '../i18n/translations';
interface Props { t: Translations['contact'] }
const { t } = Astro.props;
const socials = [
  { label: 'LinkedIn', href: 'https://linkedin.com/in/maurobrandan' },
  { label: 'GitHub', href: 'https://github.com/MauroBrandan' },
  { label: 'Email', href: 'mailto:maurobrandan.mb@gmail.com' },
];
---

<section class="contact" id="contact">
  <div class="glow glow-center" aria-hidden="true"></div>
  <div class="glow glow-violet" aria-hidden="true"></div>
  <div class="contact-inner">
    <h2 class="contact-heading">{t.heading}</h2>
    <p class="contact-sub">{t.sub}</p>
    <p class="contact-support">{t.supportingCopy}</p>
    <a href="mailto:maurobrandan.mb@gmail.com" class="contact-btn">{t.cta}</a>
    <div class="social-links">
      {socials.map(social => (
        <a href={social.href} class="social-link" target="_blank" rel="noopener noreferrer">
          {social.label}
        </a>
      ))}
    </div>
    <span class="availability">{t.availability}</span>
  </div>
</section>

<style>
  .contact {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .glow-center {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(74,158,255,0.06) 0%, transparent 70%);
  }

  .glow-violet {
    bottom: -60px;
    right: 20%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(124,111,255,0.05) 0%, transparent 70%);
  }

  .contact-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    padding: 0 120px;
    text-align: center;
  }

  .contact-heading {
    font-family: 'Inter', sans-serif;
    font-size: 48px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.1;
  }

  .contact-sub {
    font-family: 'Inter', sans-serif;
    font-size: 20px;
    color: var(--text-secondary);
    margin: 0;
  }

  .contact-support {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    color: var(--text-secondary);
    margin: 0;
    max-width: 500px;
    line-height: 1.6;
  }

  .contact-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    background-color: var(--accent-blue);
    color: #ffffff;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.2s;
    margin-top: 4px;
  }

  .contact-btn:hover {
    opacity: 0.85;
  }

  .social-links {
    display: flex;
    gap: 32px;
  }

  .social-link {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s;
  }

  .social-link:hover {
    color: var(--text-primary);
  }

  .availability {
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    color: var(--text-secondary);
    padding: 6px 14px;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-tag);
    margin-top: 4px;
  }

  @media (max-width: 768px) {
    .contact-inner {
      padding: 0 24px;
    }
    .contact-heading {
      font-size: 32px;
    }
    .social-links {
      gap: 24px;
      flex-wrap: wrap;
      justify-content: center;
    }
  }
</style>
