---
import type { Translations } from '../i18n/translations';
interface Props { t: Translations['hero'] }
const { t } = Astro.props;
const badges = ['React', 'TypeScript', 'Node.js', 'AI'];
---

<section class="hero">
  <div class="dot-grid" aria-hidden="true"></div>
  <div class="hero-content">
    <div class="hero-text">
      <h1 class="headline">{t.headline}</h1>
      <p class="subline">{t.subline}</p>
      <p class="desc">TypeScript · React · Node.js · AI Integrations</p>
      <div class="cta-row">
        <a href="#projects" class="btn-primary">{t.viewProjects}</a>
        <a href="#contact" class="btn-secondary">{t.getInTouch}</a>
      </div>
      <div class="badge-row">
        {badges.map((badge, i) => (
          <span class={`badge ${i === badges.length - 1 ? 'badge-accent' : ''}`}>{badge}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 700px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px);
    background-size: 120px 120px;
    opacity: 0.9;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 120px;
    width: 100%;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    text-align: center;
  }

  .headline {
    font-family: 'Inter', sans-serif;
    font-size: 72px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.1;
  }

  .subline {
    font-family: 'Inter', sans-serif;
    font-size: 36px;
    font-weight: 500;
    color: var(--text-secondary);
    margin: 0;
  }

  .desc {
    font-family: 'Geist Mono', monospace;
    font-size: 16px;
    font-weight: 400;
    color: var(--text-secondary);
    letter-spacing: 1px;
    margin: 0;
  }

  .cta-row {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    background-color: var(--accent-blue);
    color: #ffffff;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .btn-primary:hover {
    opacity: 0.85;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    border: 1px solid var(--border-subtle);
    color: var(--text-primary);
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .btn-secondary:hover {
    border-color: var(--text-secondary);
  }

  .badge-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 6px 12px;
    background-color: var(--bg-surface-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-tag);
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .badge-accent {
    border-color: color-mix(in srgb, var(--accent-blue) 40%, transparent);
    color: var(--accent-blue);
  }

  @media (max-width: 768px) {
    .hero {
      height: auto;
      padding: 80px 0;
    }
    .hero-content {
      padding: 0 24px;
    }
    .headline {
      font-size: 40px;
    }
    .subline {
      font-size: 22px;
    }
    .cta-row {
      flex-direction: column;
      width: 100%;
    }
    .btn-primary, .btn-secondary {
      width: 100%;
      justify-content: center;
    }
  }
</style>
