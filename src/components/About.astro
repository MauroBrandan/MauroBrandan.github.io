---
import type { Translations } from '../i18n/translations';
interface Props { t: Translations['about'] }
const { t } = Astro.props;
---

<section class="about" id="about">
  <div class="glow glow-top" aria-hidden="true"></div>
  <div class="glow glow-bottom" aria-hidden="true"></div>
  <div class="about-inner">
    <span class="section-label">{t.label}</span>
    <div class="about-columns">
      <div class="about-text">
        <h2 class="about-title">{t.title}</h2>
        <p class="about-para">{t.para1}</p>
        <p class="about-para">{t.para2}</p>
        <p class="about-para">{t.para3}</p>
        <a href="#" class="about-cta">{t.cta}</a>
      </div>
      <div class="photo-frame">
        <img src="/assets/profile.png" alt="Developer Photo" class="photo" />
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    position: relative;
    min-height: 686px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .glow-top {
    top: 0px;
    right: -100px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(74,158,255,0.07) 15%, transparent 70%);
  }

  .glow-bottom {
    bottom: -60px;
    left: -60px;
    width: 280px;
    height: 280px;
    background: radial-gradient(circle, rgba(74,158,255,0.05) 0%, transparent 70%);
  }

  .about-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 100px 120px;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .section-label {
    font-family: 'Geist Mono', monospace;
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 2px;
    color: var(--text-secondary);
    text-transform: uppercase;
  }

  .about-columns {
    display: flex;
    gap: 64px;
    align-items: flex-start;
  }

  .about-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .about-title {
    font-family: 'Inter', sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    line-height: 1.3;
  }

  .about-para {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .about-cta {
    display: inline-flex;
    align-items: center;
    padding: 12px 24px;
    border: 1px solid var(--border-subtle);
    color: var(--text-primary);
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s;
    width: fit-content;
    margin-top: 8px;
  }

  .about-cta:hover {
    border-color: var(--text-secondary);
  }

  .photo-frame {
    width: 380px;
    height: 460px;
    flex-shrink: 0;
    background-color: var(--bg-surface);
    border-radius: var(--radius-card);
    border: 1px solid rgba(74, 158, 255, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-card);
  }

  @media (max-width: 768px) {
    .about-inner {
      padding: 60px 24px;
    }
    .about-columns {
      flex-direction: column-reverse;
    }
    .photo-frame {
      width: 100%;
      height: 280px;
    }

    .photo {
      object-position: 0% 0%;
    }
  }
</style>
