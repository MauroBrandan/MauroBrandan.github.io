---
import type { Translations } from '../i18n/translations';
interface Props { t: Translations['projects'] }
const { t } = Astro.props;
---

<section class="projects" id="projects">
  <div class="glow glow-blue" aria-hidden="true"></div>
  <div class="glow glow-violet" aria-hidden="true"></div>
  <div class="projects-inner">
    <div class="projects-header">
      <span class="section-label">{t.label}</span>
      <p class="section-subtitle">{t.subtitle}</p>
    </div>
    <div class="cards">
      {t.items.map(project => (
        <div class="card-tilt">
          <article class="card">
            <div class="card-glare"></div>
            <div class="card-screenshot">
              <img src={project.coverImage} alt={`${project.title} Screenshot`} class="screenshot" />
            </div>
            <div class="card-body">
              <div class="card-meta">
                <span class="card-meta-type">{project.meta.type}</span>
                <span class="card-meta-period">{project.meta.period}</span>
              </div>
              <h3 class="card-title">{project.title}</h3>
              <p class="card-desc">{project.description}</p>
              <div class="tag-row">
                {project.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <a href={project.href} class="card-cta" target="_blank" rel="noopener noreferrer">{project.cta}</a>
            </div>
          </article>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    position: relative;
    min-height: 652px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .glow-blue {
    top: 0px;
    left: -80px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(74,158,255,0.1) 0%, transparent 70%);
  }

  .glow-violet {
    bottom: 0px;
    right: -80px;
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, rgba(124,111,255,0.1) 0%, transparent 70%);
  }

  .projects-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 100px 120px;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .projects-header {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .section-label {
    font-family: 'Geist Mono', monospace;
    font-size: 14px;
    letter-spacing: 2px;
    color: var(--text-secondary);
    text-transform: uppercase;
  }

  .section-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: var(--text-secondary);
    margin: 0;
  }

  .cards {
    display: flex;
    gap: 32px;
  }

  .card-tilt {
    flex: 1;
    perspective: 800px;
  }

  .card {
    position: relative;
    background-color: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-card);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transform-style: preserve-3d;
    transition: transform 0.15s ease-out, box-shadow 0.15s ease-out;
    will-change: transform;
  }

  .card-tilt:hover .card {
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3), 0 0 30px rgba(74, 158, 255, 0.05);
  }

  .card-glare {
    position: absolute;
    inset: 0;
    z-index: 10;
    border-radius: var(--radius-card);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease-out;
    background: radial-gradient(
      ellipse at 50% 50%,
      rgba(255, 255, 255, 0.12) 0%,
      transparent 70%
    );
  }

  .card-tilt:hover .card-glare {
    opacity: 1;
  }

  .card-screenshot {
    height: 200px;
    background-color: var(--bg-surface-2);
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--border-subtle);
  }

  .screenshot {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-body {
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-meta-type {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--text-secondary);
  }

  .card-meta-period {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--text-secondary);
  }

  .card-title {
    font-family: 'Inter', sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .card-desc {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.5;
    color: var(--text-secondary);
    margin: 0;
    flex: 1;
  }

  .tag-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .tag {
    padding: 4px 10px;
    background-color: var(--bg-surface-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-tag);
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--text-secondary);
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    border: 1px solid var(--border-subtle);
    background: none;
    color: var(--text-primary);
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    border-radius: 6px;
    cursor: pointer;
    transition: border-color 0.2s;
    width: fit-content;
    margin-top: 4px;
  }

  .card-cta:hover {
    border-color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .projects-inner {
      padding: 60px 24px;
    }
    .cards {
      flex-direction: column;
    }
  }
</style>

<script>
  function initTiltCards() {
    const tiltContainers = document.querySelectorAll<HTMLElement>('.card-tilt');
    const maxRotation = 12;

    tiltContainers.forEach(container => {
      const card = container.querySelector<HTMLElement>('.card');
      const glare = container.querySelector<HTMLElement>('.card-glare');
      if (!card || !glare) return;

      container.addEventListener('mousemove', (e) => {
        const rect = container.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width;
        const y = (e.clientY - rect.top) / rect.height;

        const rotateY = (x - 0.5) * maxRotation;
        const rotateX = (0.5 - y) * maxRotation;

        card.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;

        const glareX = x * 100;
        const glareY = y * 100;
        glare.style.background = `radial-gradient(ellipse at ${glareX}% ${glareY}%, rgba(255,255,255,0.12) 0%, transparent 70%)`;
      });

      container.addEventListener('mouseleave', () => {
        card.style.transform = 'rotateX(0deg) rotateY(0deg)';
        glare.style.opacity = '0';
      });

      container.addEventListener('mouseenter', () => {
        glare.style.opacity = '1';
      });
    });
  }

  initTiltCards();
  document.addEventListener('astro:after-swap', initTiltCards);
</script>
