---
import type { Translations } from '../i18n/translations';
interface Props { t: Translations['projects'] }
const { t } = Astro.props;
---

<section class="projects" id="projects">
  <div class="glow glow-blue" aria-hidden="true"></div>
  <div class="glow glow-violet" aria-hidden="true"></div>
  <div class="projects-inner">
    <div class="projects-header">
      <span class="section-label">{t.label}</span>
      <p class="section-subtitle">{t.subtitle}</p>
    </div>
    <div class="cards">
      {t.items.map(project => (
        <article class="card">
          <div class="card-screenshot">
            <img src={project.coverImage} alt={`${project.title} Screenshot`} class="screenshot" />
          </div>
          <div class="card-body">
            <div class="card-meta">
              <span class="card-meta-type">{project.meta.type}</span>
              <span class="card-meta-period">{project.meta.period}</span>
            </div>
            <h3 class="card-title">{project.title}</h3>
            <p class="card-desc">{project.description}</p>
            <div class="tag-row">
              {project.tags.map(tag => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <button class="card-cta">{project.cta}</button>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    position: relative;
    min-height: 652px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .glow {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .glow-blue {
    top: 0px;
    left: -80px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(74,158,255,0.1) 0%, transparent 70%);
  }

  .glow-violet {
    bottom: 0px;
    right: -80px;
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, rgba(124,111,255,0.1) 0%, transparent 70%);
  }

  .projects-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 100px 120px;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .projects-header {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .section-label {
    font-family: 'Geist Mono', monospace;
    font-size: 14px;
    letter-spacing: 2px;
    color: var(--text-secondary);
    text-transform: uppercase;
  }

  .section-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: var(--text-secondary);
    margin: 0;
  }

  .cards {
    display: flex;
    gap: 32px;
  }

  .card {
    flex: 1;
    background-color: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-card);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .card-screenshot {
    height: 200px;
    background-color: var(--bg-surface-2);
    display: flex;
    align-items: center;
    justify-content: center;
    border-bottom: 1px solid var(--border-subtle);
  }

  .screenshot {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-body {
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .card-meta-type {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--text-secondary);
  }

  .card-meta-period {
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--text-secondary);
  }

  .card-title {
    font-family: 'Inter', sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .card-desc {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.5;
    color: var(--text-secondary);
    margin: 0;
    flex: 1;
  }

  .tag-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .tag {
    padding: 4px 10px;
    background-color: var(--bg-surface-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-tag);
    font-family: 'Geist Mono', monospace;
    font-size: 11px;
    color: var(--text-secondary);
  }

  .card-cta {
    display: inline-flex;
    align-items: center;
    padding: 10px 20px;
    border: 1px solid var(--border-subtle);
    background: none;
    color: var(--text-primary);
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    border-radius: 6px;
    cursor: pointer;
    transition: border-color 0.2s;
    width: fit-content;
    margin-top: 4px;
  }

  .card-cta:hover {
    border-color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .projects-inner {
      padding: 60px 24px;
    }
    .cards {
      flex-direction: column;
    }
  }
</style>
