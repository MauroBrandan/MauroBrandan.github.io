---
import type { Translations } from '../i18n/translations';
interface Props { t: Translations['footer'] }
const { t } = Astro.props;
---

<footer class="footer">
  <span class="footer-text">{t.text}</span>
</footer>

<style>
  .footer {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px 120px;
    border-top: 1px solid var(--border-subtle);
  }

  .footer-text {
    font-family: 'Geist Mono', monospace;
    font-size: 12px;
    color: #555555;
  }

  @media (max-width: 768px) {
    .footer {
      padding: 32px 24px;
      text-align: center;
    }
  }
</style>
